<?xml version="1.0" encoding="utf-8"?>
<!-- Widget « Site » Glance (Android). Miroir de SiteMediumView iOS : nom + période,
     visiteurs + delta, courbe pleine largeur, puis « N pages vues ». -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sw_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/glance_widget_bg"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/sw_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- En-tête : nom + période à gauche, visiteurs + delta à droite -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_toStartOf="@+id/sw_stats"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/sw_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="—"
                    android:textColor="@color/gt_fg"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:id="@+id/sw_period"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:textColor="@color/gt_fg3"
                    android:textSize="11sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/sw_stats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="end"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/sw_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="@color/gt_fg"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
                <TextView
                    android:id="@+id/sw_delta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Courbe -->
        <ImageView
            android:id="@+id/sw_spark"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:scaleType="fitXY"
            android:contentDescription="Courbe des visiteurs" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp"
            android:background="@color/gt_line"
            android:contentDescription="@null" />

        <!-- Pied : N pages vues -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/sw_pageviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/gt_fg"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:text="pages vues"
                android:textColor="@color/gt_fg2"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/sw_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="Ouvrez Glance"
        android:textColor="@color/gt_fg2"
        android:textSize="12sp"
        android:visibility="gone" />
</LinearLayout>
