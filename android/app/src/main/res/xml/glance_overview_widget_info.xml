<?xml version="1.0" encoding="utf-8"?>
<!-- Widget « Aperçu » : cible 4×2 (redimensionnable). L'app republie à chaque
     ouverture ; updatePeriodMillis min. autorisé = 30 min (1800000). -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:minResizeWidth="180dp"
    android:minResizeHeight="80dp"
    android:maxResizeWidth="360dp"
    android:maxResizeHeight="280dp"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:initialLayout="@layout/glance_widget_loading"
    android:description="@string/glance_widget_description"
    android:previewLayout="@layout/glance_widget"
    android:updatePeriodMillis="1800000" />
