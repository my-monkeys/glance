default_platform(:ios)

# Build iOS + upload TestFlight. Les profils App Store (app + extension widget)
# sont créés/téléchargés via la clé API (get_provisioning_profile) puis l'export
# se fait en signature MANUELLE → évite l'erreur « Cloud signing permission »
# rencontrée avec la signature automatique à l'export.
APP_ID = "fr.mymonkey.glance"
WIDGET_ID = "fr.mymonkey.glance.GlanceWidget"
APP_PROFILE = "Glance App Store CI"
WIDGET_PROFILE = "Glance Widget App Store CI"

platform :ios do
  desc "Build the app and upload it to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    # Profils App Store (créés si absents), installés localement.
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: APP_ID,
      provisioning_name: APP_PROFILE,
      force: true
    )
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: WIDGET_ID,
      provisioning_name: WIDGET_PROFILE,
      force: true
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath", ENV["ASC_KEY_PATH"],
        "-authenticationKeyID", ENV["ASC_KEY_ID"],
        "-authenticationKeyIssuerID", ENV["ASC_ISSUER_ID"]
      ].join(" "),
      export_options: {
        signingStyle: "manual",
        provisioningProfiles: {
          APP_ID => APP_PROFILE,
          WIDGET_ID => WIDGET_PROFILE
        }
      },
      output_directory: "build",
      output_name: "Glance.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
