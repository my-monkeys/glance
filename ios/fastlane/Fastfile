default_platform(:ios)

# Build iOS + upload TestFlight, signature AUTOMATIQUE via la clé App Store
# Connect (xcodebuild -allowProvisioningUpdates gère les profils du Runner ET de
# l'extension widget). Utilisé par le workflow GitHub Actions build-ios.yml.
platform :ios do
  desc "Build the app and upload it to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      configuration: "Release",
      export_method: "app-store",
      export_options: { signingStyle: "automatic" },
      xcargs: [
        "-allowProvisioningUpdates",
        "-authenticationKeyPath", ENV["ASC_KEY_PATH"],
        "-authenticationKeyID", ENV["ASC_KEY_ID"],
        "-authenticationKeyIssuerID", ENV["ASC_ISSUER_ID"]
      ].join(" "),
      output_directory: "build",
      output_name: "Glance.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
